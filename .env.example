# Know Me — required environment variables
# Copy to .env for local development. Never commit .env to git.

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_FALLBACK_API_KEY=your-openai-fallback-api-key-here
OPENAI_FALLBACK_CHAT_MODEL=gpt-4o-mini
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:5173
EASC_SIMILARITY_THRESHOLD=0.72
EASC_MIN_CHUNK_TOKENS=80
EASC_MAX_CHUNK_TOKENS=250
EASC_HARD_CEILING_TOKENS=400
